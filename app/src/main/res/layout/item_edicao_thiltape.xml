<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:text="@string/titulo_thiltape_linha" />

        <EditText
            android:id="@+id/et_nome_thiltape_edicao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_nome_thiltape"
            android:inputType="text" />

        <EditText
            android:id="@+id/et_pontos_thiltape_edicao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_pontos"
            android:inputType="number" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/et_lat_edicao"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/hint_lat"
                android:inputType="numberDecimal|numberSigned" />

            <EditText
                android:id="@+id/et_lng_edicao"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/hint_lng"
                android:inputType="numberDecimal|numberSigned" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_foto_thiltape_edicao"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_foto" />

            <Button
                android:id="@+id/btn_gps_thiltape_edicao"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_usar_gps" />
        </LinearLayout>

        <ImageView
            android:id="@+id/iv_preview_thiltape_edicao"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="#EEEEEE"
            android:contentDescription="@string/hint_preview"
            android:scaleType="centerInside" />

        <Button
            android:id="@+id/btn_remover_thiltape_edicao"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/remover_linha" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
